# ─────────────────────────────────────────────────────────────
#  Sentinel Face — Variables de entorno
#  Copia este archivo como .env y reemplaza los valores entre < >
# ─────────────────────────────────────────────────────────────

# ── Base de datos MariaDB ─────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<tu_contraseña>
DB_NAME=<nombre_de_la_base_de_datos>

# Tamaño del pool de conexiones a MySQL (default: 10)
DB_POOL_SIZE=10

# ── Seguridad JWT ─────────────────────────────────────────────
# Genera un valor seguro con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<clave_secreta_aleatoria_minimo_32_caracteres>

# TTL del access token en segundos (default: 3600 = 1 hora)
JWT_ACCESS_TOKEN_EXPIRES=3600

# ── CORS ──────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (ej: https://mi-app.com,https://admin.mi-app.com)
# Para desarrollo local: http://localhost:8081,http://localhost:19006
ALLOWED_ORIGINS=https://tu-frontend.com

# ── Rate Limiting ─────────────────────────────────────────────
# Backend de almacenamiento para rate limiting (default: memory://)
# Para producción con múltiples instancias usar Redis: redis://localhost:6379
RATELIMIT_STORAGE_URL=memory://

# ── Usuario administrador por defecto (solo para seed inicial) ─
ADMIN_DEFAULT_EMAIL=admin@tu-dominio.com
ADMIN_DEFAULT_PASSWORD=  # Usar una contraseña fuerte; mínimo 16 caracteres
